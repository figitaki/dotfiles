-formatter-pretty@1.2.0","_npmVersion":"5.3.0","_nodeVersion":"8.4.0","_npmUser":{"name":"sindresorhus","email":"sindresorhus@gmail.com"},"dist":{"integrity":"sha512-uBBKj+Kp/2nY0wtUhf0QkHOVd4/1vII/oukkAhyoWRhg5AcgHedsYP0MJqGOxZBoG0CwBbKE3jOjmgI5dgvvJg==","shasum":"af9d8b9afe156ea6fda55d49f499a8b2df1ca3a9","tarball":"https://registry.npmjs.org/eslint-formatter-pretty/-/eslint-formatter-pretty-1.2.0.tgz"},"maintainers":[{"name":"sindresorhus","email":"sindresorhus@gmail.com"}],"_npmOperationalInternal":{"host":"s3://npm-registry-packages","tmp":"tmp/eslint-formatter-pretty-1.2.0.tgz_1504581894910_0.14759632968343794"},"directories":{}},"1.3.0":{"name":"eslint-formatter-pretty","version":"1.3.0","description":"Pretty ESLint formatter","license":"MIT","repository":{"type":"git","url":"git+https://github.com/sindresorhus/eslint-formatter-pretty.git"},"author":{"name":"Sindre Sorhus","email":"sindresorhus@gmail.com","url":"sindresorhus.com"},"engines":{"node":">=4"},"scripts":{"test":"xo && ava"},"files":["index.js"],"keywords":["eslint","eslint-formatter","formatter","reporter","lint","validate"],"dependencies":{"ansi-escapes":"^2.0.0","chalk":"^2.1.0","log-symbols":"^2.0.0","plur":"^2.1.2","string-width":"^2.0.0"},"devDependencies":{"ava":"*","strip-ansi":"^4.0.0","xo":"*"},"gitHead":"e3e80c12955e60a9af49ae7410e4c73450aba452","bugs":{"url":"https://github.com/sindresorhus/eslint-formatter-pretty/issues"},"homepage":"https://github.com/sindresorhus/eslint-formatter-pretty#readme","_id":"eslint-formatter-pretty@1.3.0","_npmVersion":"5.3.0","_nodeVersion":"8.4.0","_npmUser":{"name":"sindresorhus","email":"sindresorhus@gmail.com"},"dist":{"integrity":"sha512-5DY64Y1rYCm7cfFDHEGUn54bvCnK+wSUVF07N8oXeqUJFSd+gnYOTXbzelQ1HurESluY6gnEQPmXOIkB4Wa+gA==","shasum":"985d9e41c1f8475f4a090c5dbd2dfcf2821d607e","tarball":"https://registry.npmjs.org/eslint-formatter-pretty/-/eslint-formatter-pretty-1.3.0.tgz"},"maintainers":[{"name":"sindresorhus","email":"sindresorhus@gmail.com"}],"_npmOperationalInternal":{"host":"s3://npm-registry-packages","tmp":"tmp/eslint-formatter-pretty-1.3.0.tgz_1504584880077_0.03952236077748239"},"directories":{}}},"readme":"# eslint-formatter-pretty [![Build Status](https://travis-ci.org/sindresorhus/eslint-formatter-pretty.svg?branch=master)](https://travis-ci.org/sindresorhus/eslint-formatter-pretty)\n\n> Pretty formatter for [ESLint](https://eslint.org)\n\n![](screenshot.png)\n\n\n## Install\n\n```\n$ npm install --save-dev eslint-formatter-pretty\n```\n\n\n## Usage\n\n### ESLint CLI\n\n```\n$ eslint --format=node_modules/eslint-formatter-pretty file.js\n```\n\n### [grunt-eslint](https://github.com/sindresorhus/grunt-eslint)\n\n```js\ngrunt.initConfig({\n\teslint: {\n\t\toptions: {\n\t\t\tformat: 'node_modules/eslint-formatter-pretty'\n\t\t},\n\t\ttarget: ['file.js']\n\t}\n});\n\ngrunt.loadNpmTasks('grunt-eslint');\ngrunt.registerTask('default', ['eslint']);\n```\n\n### [gulp-eslint](https://github.com/adametry/gulp-eslint)\n\n```js\nconst gulp = require('gulp');\nconst eslint = require('gulp-eslint');\n\ngulp.task('lint', () =>\n\tgulp.src('file.js')\n\t\t.pipe(eslint())\n\t\t.pipe(eslint.format('node_modules/eslint-formatter-pretty'))\n);\n```\n\n### [eslint-loader](https://github.com/MoOx/eslint-loader) *(webpack)*\n\n#### webpack v1\n\n```js\nmodule.exports = {\n\tentry: ['file.js'],\n\toutput: {\n\t\tpath: 'dist',\n\t\tfilename: '[name].js'\n\t},\n\tmodule: {\n\t\tpreLoaders: [\n\t\t\t{\n\t\t\t\ttest: /\\.js$/,\n\t\t\t\tloader: 'eslint-loader',\n\t\t\t\texclude: /node_modules/\n\t\t\t}\n\t\t]\n\t},\n\teslint: {\n\t\tformatter: require('eslint-formatter-pretty')\n\t}\n};\n```\n\n#### webpack v2\n\n```js\nmodule.exports = {\n\tentry: ['file.js'],\n\toutput: {\n\t\tpath: 'dist',\n\t\tfilename: '[name].js'\n\t},\n\tmodule: {\n\t\trules: [\n\t\t\t{\n\t\t\t\ttest: /\\.js$/,\n\t\t\t\tloader: 'eslint-loader'\n\t\t\t}\n\t\t]\n\t},\n\tplugins: [\n\t\tnew webpack.LoaderOptionsPlugin({\n\t\t\toptions: {\n\t\t\t\teslint: {\n\t\t\t\t\tformatter: require('eslint-formatter-pretty')\n\t\t\t\t}\n\t\t\t}\n\t\t})\n\t]\n};\n```\n\n\n## Tip\n\nIn iTerm, <kbd>Cmd</kbd>+click the filename header to open the file in your editor.\n\n\n## License\n\nMIT © [Sindre Sorhus](https://sindresorhus.com)\n","maintainers":[{"name":"sindresorhus","email":"sindresorhus@gmail.com"}],"time":{"modified":"2017-09-05T04:14:40.163Z","created":"2016-04-18T18:07:12.209Z","0.1.0":"2016-04-18T18:07:12.209Z","0.1.1":"2016-04-19T05:04:19.326Z","0.2.0":"2016-04-21T12:10:23.119Z","0.2.1":"2016-04-26T16:17:43.178Z","0.2.2":"2016-05-03T16:21:34.890Z","0.3.0":"2016-08-10T10:15:59.122Z","0.3.1":"2016-08-11T19:23:35.234Z","1.0.0":"2016-09-16T08:20:51.556Z","1.0.1":"2016-10-08T06:17:55.483Z","1.1.0":"2016-10-09T15:38:15.615Z","1.2.0":"2017-09-05T03:24:55.002Z","1.3.0":"2017-09-05T04:14:40.163Z"},"homepage":"https://github.com/sindresorhus/eslint-formatter-pretty#readme","keywords":["eslint","eslint-formatter","formatter","reporter","lint","validate"],"repository":{"type":"git","url":"git+https://github.com/sindresorhus/eslint-formatter-pretty.git"},"author":{"name":"Sindre Sorhus","email":"sindresorhus@gmail.com","url":"sindresorhus.com"},"bugs":{"url":"https://github.com/sindresorhus/eslint-formatter-pretty/issues"},"license":"MIT","readmeFilename":"readme.md","users":{"netweb":true,"xueboren":true,"nice_body":true,"rocket0191":true},"_attachments":{},"_etag":"\"59ae24b0-53a4\"","_lastModified":"Tue, 5 Sep 2017 4:14:40 GMT"}