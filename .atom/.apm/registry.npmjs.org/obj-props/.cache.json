``\n\n\n## Dev\n\nThe JSON file is generated by running:\n\n```\n$ npm run generate\n```\n\n\n## License\n\nMIT © [Dustin Specker](https://github.com/dustinspecker)\n","maintainers":[{"name":"dustinspecker","email":"DustinSpecker@DustinSpecker.com"}],"time":{"modified":"2016-11-24T17:47:15.191Z","created":"2016-10-01T22:44:06.666Z","1.0.0":"2016-10-01T22:44:06.666Z","1.1.0":"2016-11-24T17:47:15.191Z"},"homepage":"https://github.com/dustinspecker/obj-props#readme","keywords":["js","javascript","ecmascript","builtin","types","type","data","props","properties","property","list","array","json","object"],"repository":{"type":"git","url":"git+https://github.com/dustinspecker/obj-props.git"},"author":{"name":"Dustin Specker","email":"DustinSpecker@DustinSpecker.com","url":"github.com/dustinspecker"},"bugs":{"url":"https://github.com/dustinspecker/obj-props/issues"},"license":"MIT","readmeFilename":"readme.md","_attachments":{},"_etag":"\"583727a3-1347\"","_lastModified":"Thu, 24 Nov 2016 17:47:15 GMT"}